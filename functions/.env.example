# 폴러 워커(Cloud Functions)의 일반 환경변수 예시 (docs/09-deployment.md §폴러 워커).
#
# 이 파일을 functions/.env 로 복사해 쓴다. firebase-tools 가 배포 시 .env 를 읽어
# 함수 런타임에 넣는다. .env 는 커밋 대상이 아니다.
#
# 비밀값(GEMINI_API_KEY · OPENF1_USERNAME · OPENF1_PASSWORD)은 여기에 두지 않는다.
# `firebase functions:secrets:set <이름>` 으로 Secret Manager 에 등록한다.

# 생성할 해설 변형. "locale:explanationLevel" 을 쉼표로 잇는다.
# locale: en | ko | ja / explanationLevel: beginner | standard | expert
#
# 변형 하나당 이벤트마다 LLM 호출과 Firestore 쓰기가 곱해진다(레이스당 이벤트 약 47건).
# 비워 두거나 유효한 항목이 없으면 기본값 ko:standard 로 되돌아간다.
COMMENTARY_VARIANTS=ko:standard

# 해설·Q&A 모델. 비우면 코드 기본값(gemini-3.5-flash)을 쓴다.
# GEMINI_MODEL=gemini-3.5-flash

# 프록시를 거칠 때만 지정한다. 비우면 Google 기본 엔드포인트다.
# GEMINI_BASE_URL=
