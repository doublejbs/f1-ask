# 데이터 모드: mock | replay | live
#  - mock:   결정론적 시뮬레이션 (Firebase 불필요)
#  - replay: 실제 OpenF1 과거 세션 녹화 재생 (Firebase 불필요)
#  - live:   Firestore 공개 경기 데이터 실시간 구독
NEXT_PUBLIC_DATA_MODE=mock

# Live 모드에서 구독할 세션 ID
NEXT_PUBLIC_LIVE_SESSION_ID=2023-singapore-race

# Firebase Emulator 연결 여부 (development 에서만 true 권장)
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=false

# Firebase 공개 설정 — mock/replay 모드에서는 불필요.
# live 모드에서 Firestore 연결 시 채운다. (Emulator 데모는 demo 값으로 충분)
NEXT_PUBLIC_FIREBASE_API_KEY=demo
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=demo-f1.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-f1
NEXT_PUBLIC_FIREBASE_APP_ID=demo

# ── "지금 볼 것" 감지 임계값 ────────────────────────────────────────────
# docs/19-watch-now.md §감지기와 임계값. 전부 선택이며, 비워 두면 실측으로 정한
# 도메인 기본값이 쓰인다(아래 주석의 값이 그 기본값이다).
# 레이스를 보면서 체감을 조절하기 위한 손잡이다 — 코드를 고칠 필요가 없다.
#
# 임계값은 비밀이 아니라 문서에 공개된 숫자라 NEXT_PUBLIC_ 접두사로 둔다.
# (접두사가 붙으면 클라이언트 번들에 인라인된다. 비밀은 절대 여기 두지 않는다)
#
# A. 타이어가 이 랩수에 도달하면 발화
# NEXT_PUBLIC_WATCH_NOW_TIRE_AGE_LAPS=20
# B. 앞차 간격이 이 값(초) 아래로 내려가면 수렴
# NEXT_PUBLIC_WATCH_NOW_GAP_SECONDS=1.0
# B. 위 조건이 유지되어야 하는 연속 관측 횟수 (폴러 주기 약 6초 → 3회 ≈ 18초)
# NEXT_PUBLIC_WATCH_NOW_GAP_SAMPLES=3
# B. 재무장 배수 — 경계를 오가며 반복 발화하는 것을 막는다
# NEXT_PUBLIC_WATCH_NOW_GAP_REARM_MULTIPLIER=2
# C. 내 뒤 이 계단 이내의 차가 피트인하면 언더컷 위협
# NEXT_PUBLIC_WATCH_NOW_UNDERCUT_POSITION_GAP=2
# D. 기준점 대비 이 계단 이상 순위가 변하면 발화
# NEXT_PUBLIC_WATCH_NOW_POSITION_SWING=3
# SC · VSC 중 간격 기반 감지(B) 억제 여부
# NEXT_PUBLIC_WATCH_NOW_SUPPRESS_GAP_DURING_SAFETY_CAR=true

# ── AI provider (서버 전용) ─────────────────────────────────────────────
# 절대 NEXT_PUBLIC_ 접두사를 붙이지 않는다 — 붙이면 키가 클라이언트 번들에 노출된다.
# 아래 우선순위로 첫 번째로 설정된 키의 provider 를 쓰고, 하나도 없으면 Mock 으로 동작한다.
# 어떤 provider 든 호출 실패 시 결정론적 Mock 으로 fallback 한다.
#
# 1) Gemini — 무료 티어가 있어 실제 LLM 경로 검증에 적합하다.
# GEMINI_API_KEY=
# GEMINI_MODEL 은 설정하지 않는 것이 정상이다 — 코드 기본값(gemini-3.5-flash)을 쓴다.
# 이전 기본값이던 gemini-2.5-flash 는 신규 사용자에게 닫혀 generateContent 가 404 를 반환한다.
# GEMINI_MODEL=gemini-3.5-flash
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
#
# 2) Claude (Anthropic)
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
#
# 3) OpenAI
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
